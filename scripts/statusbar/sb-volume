#!/bin/sh
# Volume + Mic + Output indicator for dwmblocks (PipeWire)

set -e

# ---------- Click handling ----------
case $BLOCK_BUTTON in
  1) wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle ;;   # toggle mic
  2) wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle ;;     # toggle speakers
  3) setsid -f pavucontrol ;;
  4) wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%+ ;;
  5) wpctl set-volume @DEFAULT_AUDIO_SINK@ 1%- ;;
esac


# ---------- Mic indicator ----------
mic_raw="$(wpctl get-volume @DEFAULT_AUDIO_SOURCE@)"

if echo "$mic_raw" | grep -q MUTED; then
  MIC_ICON="󰍭"
else
  MIC_ICON="󰍬"
fi


# ---------- Volume ----------
vol_raw="$(wpctl get-volume @DEFAULT_AUDIO_SINK@)"

if echo "$vol_raw" | grep -q MUTED; then
  VOL_ICON="🔇"
  VOL_TXT=""
else
  vol="$(echo "$vol_raw" | awk '{printf "%d",$2*100}')"

  if [ "$vol" -ge 70 ]; then
    VOL_ICON="🔊"
  elif [ "$vol" -ge 30 ]; then
    VOL_ICON="🔉"
  else
    VOL_ICON="🔈"
  fi

  VOL_TXT="${vol}%"
fi


# ---------- Output device ----------
sink="$(pactl get-default-sink)"

PORT=$(pactl list sinks | awk -v s="$sink" '
$0 ~ "Name: "s {f=1}
f && /Active Port/ {print $3; exit}
')

case "$PORT" in
  analog-output-headphones) OUT="" ;;
  analog-output-speaker)    OUT="" ;;
  hdmi-output-*)            OUT="" ;;
  *)                        OUT="" ;;
esac


# ---------- Output ----------
echo " $MIC_ICON $OUT $VOL_ICON$VOL_TXT"
